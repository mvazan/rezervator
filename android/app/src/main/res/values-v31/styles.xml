<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: brand background + the adaptive icon
         (without an adaptive icon the OS wraps the legacy one in a white
         circle — the "white ring"). Windowed background mirrors the app's
         light scaffold so the handoff to Flutter's own splash is seamless. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#0F172A</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
